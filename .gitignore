# =============================================================================
# Dance of the Titans
# .gitignore
# =============================================================================

# -------------------------------
# Node.js
# -------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -------------------------------
# Environment Variables
# -------------------------------
.env
.env.local
.env.*

# -------------------------------
# macOS
# -------------------------------
.DS_Store
.AppleDouble
.LSOverride

# -------------------------------
# Windows
# -------------------------------
Thumbs.db
Desktop.ini

# -------------------------------
# Linux
# -------------------------------
*~

# -------------------------------
# IDEs
# -------------------------------
.vscode/
.idea/
*.swp
*.swo

# -------------------------------
# Logs
# -------------------------------
logs/
*.log

# -------------------------------
# Build Output
# -------------------------------
dist/
build/
coverage/

# -------------------------------
# Python
# -------------------------------
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/

# -------------------------------
# Temporary Files
# -------------------------------
tmp/
temp/
.cache/

# -------------------------------
# Generated Media (Optional)
# -------------------------------
*.bak

# =============================================================================
# Do NOT ignore these
# =============================================================================
# README.md
# LICENSE
# src/
# assets/
# docs/
# demo/
# CITATION.cff
# SECURITY.md
# CONTRIBUTING.md
# CODE_OF_CONDUCT.md
